{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["package.json", "turbo.json", "lefthook.yml", "biome.json"]
    },
    "apps/api": {
      "entry": ["src/main.ts", "src/**/*.module.ts", "src/**/*.spec.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/web": {
      "entry": ["src/app/app.config.ts", "src/app/app.routes.ts", "src/**/*.spec.ts"],
      "project": ["src/**/*.ts"]
    },
    "docs": {
      "project": [".vitepress/**/*.ts"]
    },
    "packages/database": {
      "entry": ["src/client.ts"],
      "project": ["src/**/*.ts", "prisma/**/*.ts"],
      "ignoreDependencies": ["@prisma/client", "pg", "@types/pg"]
    },
    "packages/pdf-extraction": {
      "entry": ["src/index.ts", "src/**/*.spec.ts"],
      "project": ["src/**/*.ts", "vitest.config.ts"]
    }
  },
  "ignoreDependencies": ["vue"]
}
