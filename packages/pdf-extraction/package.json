{
  "name": "@depot-numerique/pdf-extraction",
  "version": "0.0.1",
  "private": true,
  "description": "Extraction texte structurée des PDF métier Dépôt Numérique",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "evaluate": "pnpm build && node scripts/evaluate-corpus.mjs"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.394",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  }
}
