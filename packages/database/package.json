{
  "name": "@depot-numerique/database",
  "version": "0.0.1",
  "private": true,
  "description": "Prisma client and database schema for Dépôt Numérique",
  "main": "./dist/src/client.js",
  "types": "./dist/src/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    }
  },
  "scripts": {
    "build": "pnpm generate && tsc -p tsconfig.build.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "pnpm generate && tsc --noEmit -p tsconfig.json",
    "generate": "prisma generate",
    "validate": "prisma validate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "seed": "prisma db seed",
    "studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  }
}
