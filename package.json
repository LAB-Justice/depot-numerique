{
  "name": "depot-numerique",
  "version": "1.0.0",
  "description": "",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "turbo dev",
    "apps:dev": "turbo dev --filter api --filter web",
    "api:dev": "turbo dev --filter api",
    "web:dev": "turbo dev --filter web",
    "build": "turbo build",
    "api:build": "turbo build --filter api",
    "web:build": "turbo build --filter web",
    "docs:build": "turbo build --filter @depot-numerique/docs",
    "lint": "turbo lint",
    "api:lint": "turbo lint --filter api",
    "web:lint": "turbo lint --filter web",
    "docs:lint": "turbo lint --filter @depot-numerique/docs",
    "format": "turbo format",
    "api:format": "turbo format --filter api",
    "web:format": "turbo format --filter web",
    "docs:format": "turbo format --filter @depot-numerique/docs",
    "format:check": "turbo format:check",
    "api:format:check": "turbo format:check --filter api",
    "web:format:check": "turbo format:check --filter web",
    "docs:format:check": "turbo format:check --filter @depot-numerique/docs",
    "check": "turbo check",
    "api:check": "turbo check --filter api",
    "web:check": "turbo check --filter web",
    "docs:check": "turbo check --filter @depot-numerique/docs",
    "check:fix": "turbo check:fix",
    "api:check:fix": "turbo check:fix --filter api",
    "web:check:fix": "turbo check:fix --filter web",
    "docs:check:fix": "turbo check:fix --filter @depot-numerique/docs",
    "typecheck": "turbo typecheck",
    "api:typecheck": "turbo typecheck --filter api",
    "web:typecheck": "turbo typecheck --filter web",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "knip": "knip",
    "prepare": "lefthook install",
    "test": "turbo test",
    "api:test": "turbo test --filter api",
    "web:test": "turbo test --filter web",
    "docs:dev": "turbo dev --filter @depot-numerique/docs",
    "docs:preview": "pnpm --filter @depot-numerique/docs preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "knip": "6.18.0",
    "lefthook": "2.1.9",
    "turbo": "^2.9.18"
  }
}
