{
  "name": "depot-numerique",
  "version": "1.0.0",
  "description": "",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "turbo dev",
    "apps:dev": "turbo dev --filter api --filter web",
    "api:dev": "turbo dev --filter api",
    "web:dev": "turbo dev --filter web",
    "docs:dev": "turbo dev --filter @depot-numerique/docs",
    "docs:preview": "pnpm --filter @depot-numerique/docs preview",
    "build": "turbo build",
    "api:build": "turbo build --filter api",
    "web:build": "turbo build --filter web",
    "docs:build": "turbo build --filter @depot-numerique/docs",
    "database:build": "turbo build --filter @depot-numerique/database",
    "pdf-extraction:build": "turbo build --filter @depot-numerique/pdf-extraction",
    "pdf-extraction:evaluate": "pnpm --filter @depot-numerique/pdf-extraction evaluate",
    "root:lint": "biome lint package.json biome.json knip.json turbo.json commitlint.config.cjs",
    "lint": "pnpm root:lint && turbo lint",
    "api:lint": "turbo lint --filter api",
    "web:lint": "turbo lint --filter web",
    "docs:lint": "turbo lint --filter @depot-numerique/docs",
    "database:lint": "turbo lint --filter @depot-numerique/database",
    "pdf-extraction:lint": "turbo lint --filter @depot-numerique/pdf-extraction",
    "root:format": "biome format --write package.json biome.json knip.json turbo.json commitlint.config.cjs",
    "format": "pnpm root:format && turbo format",
    "api:format": "turbo format --filter api",
    "web:format": "turbo format --filter web",
    "docs:format": "turbo format --filter @depot-numerique/docs",
    "database:format": "turbo format --filter @depot-numerique/database",
    "pdf-extraction:format": "turbo format --filter @depot-numerique/pdf-extraction",
    "root:format:check": "biome format package.json biome.json knip.json turbo.json commitlint.config.cjs",
    "format:check": "pnpm root:format:check && turbo format:check",
    "api:format:check": "turbo format:check --filter api",
    "web:format:check": "turbo format:check --filter web",
    "docs:format:check": "turbo format:check --filter @depot-numerique/docs",
    "database:format:check": "turbo format:check --filter @depot-numerique/database",
    "pdf-extraction:format:check": "turbo format:check --filter @depot-numerique/pdf-extraction",
    "root:check": "biome check package.json biome.json knip.json turbo.json commitlint.config.cjs",
    "check": "pnpm root:check && turbo check",
    "api:check": "turbo check --filter api",
    "web:check": "turbo check --filter web",
    "docs:check": "turbo check --filter @depot-numerique/docs",
    "database:check": "turbo check --filter @depot-numerique/database",
    "pdf-extraction:check": "turbo check --filter @depot-numerique/pdf-extraction",
    "root:check:fix": "biome check --write package.json biome.json knip.json turbo.json commitlint.config.cjs",
    "check:fix": "pnpm root:check:fix && turbo check:fix",
    "api:check:fix": "turbo check:fix --filter api",
    "web:check:fix": "turbo check:fix --filter web",
    "docs:check:fix": "turbo check:fix --filter @depot-numerique/docs",
    "database:check:fix": "turbo check:fix --filter @depot-numerique/database",
    "pdf-extraction:check:fix": "turbo check:fix --filter @depot-numerique/pdf-extraction",
    "verify": "pnpm verify:check && pnpm verify:knip && pnpm verify:typecheck && pnpm verify:test",
    "verify:check": "node -e \"const title=' Biome check '; const width=process.stdout.columns||80; console.log('\\n'+title.padStart(Math.floor((width+title.length)/2),'=').padEnd(width,'='))\" && pnpm check",
    "verify:knip": "node -e \"const title=' Knip '; const width=process.stdout.columns||80; console.log('\\n'+title.padStart(Math.floor((width+title.length)/2),'=').padEnd(width,'='))\" && pnpm knip",
    "verify:typecheck": "node -e \"const title=' TypeScript typecheck '; const width=process.stdout.columns||80; console.log('\\n'+title.padStart(Math.floor((width+title.length)/2),'=').padEnd(width,'='))\" && pnpm typecheck",
    "verify:test": "node -e \"const title=' Tests '; const width=process.stdout.columns||80; console.log('\\n'+title.padStart(Math.floor((width+title.length)/2),'=').padEnd(width,'='))\" && pnpm test",
    "typecheck": "turbo typecheck",
    "api:typecheck": "turbo typecheck --filter api",
    "web:typecheck": "turbo typecheck --filter web",
    "database:typecheck": "turbo typecheck --filter @depot-numerique/database",
    "pdf-extraction:typecheck": "turbo typecheck --filter @depot-numerique/pdf-extraction",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "knip": "knip",
    "prepare": "lefthook install",
    "test": "turbo test",
    "api:test": "turbo test --filter api",
    "web:test": "turbo test --filter web",
    "pdf-extraction:test": "turbo test --filter @depot-numerique/pdf-extraction",
    "database:generate": "pnpm --filter @depot-numerique/database generate",
    "database:validate": "pnpm --filter @depot-numerique/database validate",
    "database:migrate:dev": "pnpm --filter @depot-numerique/database migrate:dev",
    "database:migrate:deploy": "pnpm --filter @depot-numerique/database migrate:deploy",
    "database:migrate:status": "pnpm --filter @depot-numerique/database migrate:status",
    "database:seed": "pnpm --filter @depot-numerique/database seed",
    "database:studio": "pnpm --filter @depot-numerique/database studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "knip": "6.18.0",
    "lefthook": "2.1.9",
    "turbo": "^2.9.18"
  }
}
